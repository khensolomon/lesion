<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="dev-lethil-lesion">

  <!-- Common: Show Apps Button Mode-->
  <enum id="dev.lethil.lesion.ButtonMode">
    <value nick="icon" value="0"/>
    <value nick="file" value="1"/>
    <value nick="text" value="2"/>
  </enum>

  <!-- Clock's Enums -->
  <enum id="dev.lethil.lesion.ClockTarget">
    <value nick="left" value="0"/>
    <value nick="right" value="1"/>
  </enum>
  <enum id="dev.lethil.lesion.ClockPosition">
    <value nick="before" value="0"/>
    <value nick="after" value="1"/>
  </enum>
  <enum id="dev.lethil.lesion.ClockFormatMode">
    <value nick="default" value="0"/>
    <value nick="custom" value="1"/>
  </enum>

  <!-- Apps's Enums -->
  <enum id="dev.lethil.lesion.HorizontalPosition">
    <value nick="left" value="0"/>
    <value nick="right" value="1"/>
  </enum>

  <!-- Common: BoxPosition for Indicator (4 sides) -->
  <enum id="dev.lethil.lesion.BoxPosition">
    <value nick="top" value="0"/>
    <value nick="right" value="1"/>
    <value nick="bottom" value="2"/>
    <value nick="left" value="3"/>
  </enum>  

  <!-- Dock's Enums -->
  <enum id="dev.lethil.lesion.DockPosition">
    <value nick="bottom" value="0"/>
    <value nick="left" value="1"/>
    <value nick="right" value="2"/>
    <value nick="top" value="3"/>
  </enum>

  <schema id="dev.lethil.lesion" path="/dev/lethil/lesion/">
    <!-- Enabled Bundled Styles -->
    <key name="enabled-styles" type="as">
      <default>[]</default>
      <summary>Enabled CSS file names</summary>
      <description>List of CSS files in style/bundled/ that are currently applied.</description>
    </key>

    <!-- Custom User Styles -->
    <key name="custom-styles" type="a(sb)">
      <default>[]</default>
      <summary>User-added custom CSS files</summary>
      <description>An array of tuples containing the file URI and its enabled state.</description>
    </key>

    <!-- Navigation -->
    <key name="open-page" type="s">
      <default>""</default>
      <summary>Page to open</summary>
    </key>

    <!-- Indicator -->
    <key name="indicator-enabled" type="b">
      <default>true</default>
      <summary>Show the extension indicator in the panel</summary>
    </key>
    <key name="indicator-custom-icon" type="s">
      <default>''</default>
      <summary>Custom icon path for the main indicator</summary>
    </key>

    <!-- Corners -->
    <key name="corners-enabled" type="b">
      <default>false</default>
      <summary>Enable custom corner rounding</summary>
    </key>
    <key name="corners-radius" type="i">
      <default>12</default>
      <summary>Border radius in pixels</summary>
    </key>
    <key name="corners-flat" type="b">
      <default>false</default>
      <summary>Force flat corners (radius 0)</summary>
    </key>

    <!-- Geometry -->
    <key name="geometry-enabled" type="b">
      <default>false</default>
      <summary>Save and restore window geometry</summary>
    </key>
    <key name="geometry-data" type="s">
      <default>"{}"</default>
      <summary>JSON string containing saved window positions</summary>
    </key>

    <!-- Clock -->
    <key name="clock-move-enabled" type="b">
      <default>true</default>
      <summary>Move the Date Menu from center</summary>
    </key>
    <!-- Target Panel Side -->
    <key name="clock-target" enum="dev.lethil.lesion.ClockTarget">
      <default>'right'</default>
      <summary>Which side of the panel to move the clock to</summary>
    </key>
    <!-- Generic Position names -->
    <key name="clock-position" enum="dev.lethil.lesion.ClockPosition">
      <default>'before'</default>
      <summary>Place before or after the anchor element</summary>
    </key>
    <!-- New Customization Keys -->
    <key name="clock-format-mode" enum="dev.lethil.lesion.ClockFormatMode">
      <default>'default'</default>
      <summary>Use system text or custom strftime format</summary>
    </key>
    <key name="clock-custom-format" type="s">
      <default>'%H:%M  %A %d'</default>
      <summary>GLib DateTime format string</summary>
    </key>
    <key name="clock-multiline" type="b">
      <default>false</default>
      <summary>Split date and time into two lines</summary>
    </key>
    <key name="clock-dim-separator" type="b">
      <default>false</default>
      <summary>Dim the separator between time and date</summary>
    </key>
    <key name="clock-custom-time" type="s">
      <default>'%H:%M'</default>
    </key>
    <key name="clock-custom-date" type="s">
      <default>'%A, %d %B'</default>
    </key>
    <!-- You can safely add more features later, e.g.:
    <key name="clock-seconds" type="b"><default>false</default></key>
    <key name="weather-enabled" type="b"><default>false</default></key>
    -->

    <!-- Apps -->
    <key name="apps-icon-size" type="i"><default>14</default></key>
    <key name="apps-icon-desaturate" type="b"><default>true</default></key>
    
    <!-- Opacity Customization -->
    <key name="apps-opacity-running" type="i"><default>255</default></key>
    <key name="apps-opacity-stopped" type="i"><default>160</default></key>

    <!-- Indicator Configuration -->
    <key name="apps-indicator-pos" enum="dev.lethil.lesion.BoxPosition"><default>'top'</default></key> 
    <key name="apps-indicator-offset" type="i"><default>12</default></key>
    <key name="apps-indicator-width" type="i"><default>4</default></key>
    <key name="apps-indicator-height" type="i"><default>4</default></key>
    <key name="apps-indicator-radius" type="i"><default>99</default></key>
    <key name="apps-indicator-color" type="s"><default>'#ffffff'</default></key>

    <!-- Favorites -->
    <key name="apps-favorites-enabled" type="b">
      <default>false</default>
    </key>
    <key name="apps-favorites-pos" enum="dev.lethil.lesion.HorizontalPosition">
      <default>'left'</default>
    </key>
    <key name="apps-favorites-index" type="i">
      <default>0</default>
    </key>

    <!-- Running Apps -->
    <key name="apps-running-enabled" type="b">
      <default>false</default>
    </key>
    <key name="apps-running-pos" enum="dev.lethil.lesion.HorizontalPosition">
      <default>'left'</default>
    </key>
    <key name="apps-running-index" type="i">
      <default>0</default>
    </key>

    <!-- Disks -->
    <key name="apps-disks-enabled" type="b">
      <default>false</default>
    </key>
    <key name="apps-disks-pos" enum="dev.lethil.lesion.HorizontalPosition">
      <default>'right'</default>
    </key>
    <key name="apps-disks-index" type="i">
      <default>1</default>
    </key>

    <!-- Trash -->
    <key name="apps-trash-enabled" type="b">
      <default>false</default>
    </key>
    <key name="apps-trash-pos" enum="dev.lethil.lesion.HorizontalPosition">
      <default>'right'</default>
    </key>
    <key name="apps-trash-index" type="i">
      <default>2</default>
    </key>
    
    <!-- Show Grid Button -->
    <key name="apps-showgrid-enabled" type="b"><default>false</default></key>
    <key name="apps-showgrid-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'left'</default></key>
    <key name="apps-showgrid-index" type="i"><default>0</default></key>
    
    <!-- NEW: Expanded Show Grid Options -->
    <key name="apps-showgrid-mode" enum="dev.lethil.lesion.ButtonMode"><default>'icon'</default></key>
    <key name="apps-showgrid-icon" type="s"><default>'start-here-symbolic'</default></key>
    <key name="apps-showgrid-path" type="s"><default>''</default></key>
    <key name="apps-showgrid-text" type="s"><default>'Apps'</default></key>

    <!-- Overview Button -->
    <key name="apps-overview-enabled" type="b"><default>false</default></key>
    <key name="apps-overview-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'left'</default></key>
    <key name="apps-overview-index" type="i"><default>0</default></key>
    <key name="apps-overview-hide-default" type="b"><default>false</default></key>

    <!-- Dock -->
    <key name="dock-enabled" type="b">
      <default>false</default>
      <summary>Enable persistent dock</summary>
    </key>
    <key name="dock-position" enum="dev.lethil.lesion.DockPosition">
      <default>'bottom'</default>
      <summary>Screen edge position</summary>
    </key>
    <key name="dock-panel-mode" type="b">
      <default>false</default>
      <summary>Extend dock to screen edges (Panel mode)</summary>
    </key>
    <key name="dock-icon-size" type="i">
      <default>48</default>
      <summary>App icon size in pixels</summary>
    </key>
    <key name="dock-radius" type="i">
      <default>16</default>
      <summary>Corner radius</summary>
    </key>
    <key name="dock-opacity" type="d">
      <default>0.8</default>
      <summary>Background opacity (0.0 to 1.0)</summary>
    </key>
    <key name="dock-color" type="s">
      <default>'#242424'</default>
      <summary>Background color hex</summary>
    </key>
    <key name="dock-autohide" type="b">
      <default>false</default>
      <summary>Intelligent auto-hide</summary>
    </key>
    <key name="dock-padding" type="i">
      <default>6</default>
      <summary>Internal padding around icons</summary>
    </key>
    <key name="dock-margin" type="i">
      <default>0</default>
      <summary>External margin from screen edge</summary>
    </key>
    <key name="dock-show-apps" type="b">
      <default>true</default>
      <summary>Show or hide the applications grid button</summary>
    </key>
    <key name="dock-item-spacing" type="i">
      <default>6</default>
      <summary>Space between icons in pixels</summary>
    </key>
    <key name="dock-item-radius" type="i">
      <default>12</default>
      <summary>Border radius of individual app buttons</summary>
    </key>
    <key name="dock-item-color" type="s">
      <default>'rgba(255,255,255,0.1)'</default>
      <summary>Background color of app buttons</summary>
    </key>
    <key name="dock-item-padding" type="i">
      <default>0</default>
      <summary>Padding inside individual app buttons</summary>
    </key>
    <key name="dock-item-margin" type="i">
      <default>0</default>
      <summary>Margin around individual app buttons</summary>
    </key>

    <key name="dock-border-width" type="i">
      <default>0</default>
      <summary>Container border width</summary>
    </key>
    <key name="dock-border-color" type="s">
      <default>'rgba(255,255,255,0.2)'</default>
      <summary>Container border color</summary>
    </key>
    <key name="dock-hover-scale" type="d">
      <default>1.0</default>
      <summary>Scale factor on hover (1.0 to 1.5)</summary>
    </key>

  </schema>
</schemalist>