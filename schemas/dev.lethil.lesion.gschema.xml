<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="dev-lethil-lesion">

  <!-- Common: Show Apps Button Mode-->
  <enum id="dev.lethil.lesion.ButtonMode">
    <value nick="icon" value="0"/>
    <value nick="file" value="1"/>
    <value nick="text" value="2"/>
  </enum>

  <!-- Clock's Enums -->
  <enum id="dev.lethil.lesion.ClockTarget">
    <value nick="left" value="0"/>
    <value nick="right" value="1"/>
  </enum>
  <enum id="dev.lethil.lesion.ClockPosition">
    <value nick="before" value="0"/>
    <value nick="after" value="1"/>
  </enum>
  <enum id="dev.lethil.lesion.ClockFormatMode">
    <value nick="default" value="0"/>
    <value nick="custom" value="1"/>
  </enum>

  <!-- Apps's Enums -->
  <enum id="dev.lethil.lesion.HorizontalPosition">
    <value nick="left" value="0"/>
    <value nick="right" value="1"/>
  </enum>

  <!-- Common: BoxPosition for Indicator (4 sides) -->
  <enum id="dev.lethil.lesion.BoxPosition">
    <value nick="top" value="0"/>
    <value nick="right" value="1"/>
    <value nick="bottom" value="2"/>
    <value nick="left" value="3"/>
  </enum>
  
  <!-- CSS Border Styles -->
  <enum id="dev.lethil.lesion.BorderStyle">
    <value nick="solid" value="0"/>
    <value nick="dotted" value="1"/>
    <value nick="dashed" value="2"/>
    <value nick="double" value="3"/>
    <value nick="groove" value="4"/>
    <value nick="ridge" value="5"/>
    <value nick="inset" value="6"/>
    <value nick="outset" value="7"/>
    <value nick="none" value="8"/>
  </enum>
  
  <!-- Blend Modes -->
  <enum id="dev.lethil.lesion.BlendMode">
    <value nick="normal" value="0"/>
    <value nick="multiply" value="1"/>
    <value nick="screen" value="2"/>
    <value nick="overlay" value="3"/>
    <value nick="darken" value="4"/>
    <value nick="lighten" value="5"/>
    <value nick="color-dodge" value="6"/>
    <value nick="color-burn" value="7"/>
    <value nick="hard-light" value="8"/>
    <value nick="soft-light" value="9"/>
    <value nick="difference" value="10"/>
    <value nick="exclusion" value="11"/>
    <value nick="hue" value="12"/>
    <value nick="saturation" value="13"/>
    <value nick="color" value="14"/>
    <value nick="luminosity" value="15"/>
  </enum>

  <schema id="dev.lethil.lesion" path="/dev/lethil/lesion/">
    <!-- WALLPAPER SECTION -->
    <key name="wallpaper-enabled" type="b">
        <default>true</default>
        <summary>Master Switch: Enable Wallpaper Management</summary>
    </key>
    
    <!-- Image Visibility -->
    <key name="wallpaper-show-image" type="b">
        <default>true</default>
        <summary>Toggle the background picture on/off</summary>
    </key>

    <!-- Effects -->
    <key name="wallpaper-monochrome" type="b">
        <default>false</default>
        <summary>Apply monochrome filter to background</summary>
    </key>
    <key name="wallpaper-blur-sigma" type="i">
        <default>0</default>
        <summary>Blur strength (sigma). 0 to disable.</summary>
    </key>
    <key name="wallpaper-brightness" type="d">
        <default>1.0</default>
        <summary>Brightness multiplier (0.0 to 1.0)</summary>
    </key>
    <!-- Custom Colors (Decoupled from System) -->
    <key name="wallpaper-primary-color-light" type="s">
        <default>''</default>
        <summary>Primary color used in Light Mode (empty = auto-import)</summary>
    </key>
    <key name="wallpaper-secondary-color-light" type="s">
        <default>''</default>
        <summary>Secondary color used in Light Mode</summary>
    </key>
    <!-- Custom Dark Mode Colors -->
    <key name="wallpaper-primary-color-dark" type="s">
        <default>'#000000'</default>
        <summary>Primary color used in Dark Mode</summary>
    </key>
    <key name="wallpaper-secondary-color-dark" type="s">
        <default>'#000000'</default>
        <summary>Secondary color used in Dark Mode</summary>
    </key>
    
    <!-- Store previous state for toggle -->
    <key name="wallpaper-restore-options" type="s">
        <default>'zoom'</default>
        <summary>Internal: stores picture-options when disabled</summary>
    </key>

    <!-- Enabled Bundled Styles -->
    <key name="enabled-styles" type="as">
      <default>[]</default>
      <summary>Enabled CSS file names</summary>
    </key>

    <!-- Custom User Styles -->
    <key name="custom-styles" type="a(sb)">
      <default>[]</default>
      <summary>User-added custom CSS files</summary>
    </key>

    <!-- Navigation -->
    <key name="open-page" type="s">
      <default>""</default>
      <summary>Page to open</summary>
    </key>

    <!-- Indicator -->
    <key name="indicator-enabled" type="b">
      <default>true</default>
      <summary>Show the extension indicator in the panel</summary>
    </key>
    <key name="indicator-custom-icon" type="s">
      <default>''</default>
      <summary>Custom icon path for the main indicator</summary>
    </key>

    <!-- Geometry -->
    <key name="geometry-enabled" type="b">
      <default>false</default>
      <summary>Save and restore window geometry</summary>
    </key>
    <key name="geometry-data" type="s">
      <default>"{}"</default>
      <summary>JSON string containing saved window positions</summary>
    </key>

    <!-- Clock -->
    <key name="clock-move-enabled" type="b"><default>true</default></key>
    <key name="clock-target" enum="dev.lethil.lesion.ClockTarget"><default>'right'</default></key>
    <key name="clock-position" enum="dev.lethil.lesion.ClockPosition"><default>'before'</default></key>
    <key name="clock-format-mode" enum="dev.lethil.lesion.ClockFormatMode"><default>'default'</default></key>
    <key name="clock-custom-format" type="s"><default>'%H:%M  %A %d'</default></key>
    <key name="clock-multiline" type="b"><default>false</default></key>
    <key name="clock-dim-separator" type="b"><default>false</default></key>
    <key name="clock-custom-time" type="s"><default>'%H:%M'</default></key>
    <key name="clock-custom-date" type="s"><default>'%A, %d %B'</default></key>

    <!-- Apps -->
    <key name="apps-icon-size" type="i"><default>16</default></key>
    <key name="apps-icon-desaturate" type="b"><default>true</default></key>
    <key name="apps-opacity-running" type="i"><default>255</default></key>
    <key name="apps-opacity-stopped" type="i"><default>160</default></key>

    <!-- Indicator Configuration -->
    <key name="apps-indicator-pos" enum="dev.lethil.lesion.BoxPosition"><default>'top'</default></key> 
    <key name="apps-indicator-offset" type="i"><default>12</default></key>
    <key name="apps-indicator-width" type="i"><default>4</default></key>
    <key name="apps-indicator-height" type="i"><default>4</default></key>
    <key name="apps-indicator-radius" type="i"><default>99</default></key>
    <key name="apps-indicator-color" type="s"><default>'#ffffff'</default></key>

    <!-- Favorites -->
    <key name="apps-favorites-enabled" type="b"><default>false</default></key>
    <key name="apps-favorites-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'left'</default></key>
    <key name="apps-favorites-index" type="i"><default>0</default></key>

    <!-- Running Apps -->
    <key name="apps-running-enabled" type="b"><default>false</default></key>
    <key name="apps-running-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'left'</default></key>
    <key name="apps-running-index" type="i"><default>0</default></key>

    <!-- Disks -->
    <key name="apps-disks-enabled" type="b"><default>false</default></key>
    <key name="apps-disks-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'right'</default></key>
    <key name="apps-disks-index" type="i"><default>1</default></key>

    <!-- Trash -->
    <key name="apps-trash-enabled" type="b"><default>false</default></key>
    <key name="apps-trash-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'right'</default></key>
    <key name="apps-trash-index" type="i"><default>2</default></key>
    
    <!-- Show Grid Button -->
    <key name="apps-showgrid-enabled" type="b"><default>false</default></key>
    <key name="apps-showgrid-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'left'</default></key>
    <key name="apps-showgrid-index" type="i"><default>0</default></key>
    <key name="apps-showgrid-mode" enum="dev.lethil.lesion.ButtonMode"><default>'icon'</default></key>
    <key name="apps-showgrid-icon" type="s"><default>'start-here-symbolic'</default></key>
    <key name="apps-showgrid-path" type="s"><default>''</default></key>
    <key name="apps-showgrid-text" type="s"><default>'Apps'</default></key>

    <!-- Overview Button -->
    <key name="apps-overview-enabled" type="b"><default>false</default></key>
    <key name="apps-overview-pos" enum="dev.lethil.lesion.HorizontalPosition"><default>'left'</default></key>
    <key name="apps-overview-index" type="i"><default>0</default></key>
    <key name="apps-overview-hide-default" type="b"><default>false</default></key>

    <!-- PANEL CUSTOMIZATION -->
    <key name="panel-enabled" type="b"><default>true</default></key>
    
    <!-- Panel: Bar -->
    <key name="panel-position" enum="dev.lethil.lesion.BoxPosition"><default>'top'</default></key>
    <key name="panel-bg-color" type="s"><default>'rgba(0,0,0,1)'</default></key>
    <key name="panel-bg-gradient-enabled" type="b"><default>false</default></key>
    <key name="panel-bg-gradient-color" type="s"><default>'rgba(0,0,0,0)'</default></key>
    <key name="panel-bg-gradient-dir" type="i"><default>0</default></key>
    <key name="panel-bg-blend-mode" enum="dev.lethil.lesion.BlendMode"><default>'normal'</default></key>

    <key name="panel-border-size" type="i"><default>0</default></key>
    <key name="panel-border-style" enum="dev.lethil.lesion.BorderStyle"><default>'solid'</default></key>
    <key name="panel-border-color" type="s"><default>'rgba(255,255,255,0.2)'</default></key>
    <key name="panel-border-bottom-only" type="b"><default>true</default></key>

    <key name="panel-shadow-enabled" type="b"><default>false</default></key>
    <key name="panel-shadow-color" type="s"><default>'rgba(0,0,0,0.5)'</default></key>
    <key name="panel-shadow-inset" type="b"><default>false</default></key>
    <key name="panel-shadow-x" type="i"><default>0</default></key>
    <key name="panel-shadow-y" type="i"><default>0</default></key>
    <key name="panel-shadow-blur" type="i"><default>4</default></key>
    <key name="panel-shadow-spread" type="i"><default>0</default></key>

    <!-- Panel: Buttons -->
    <key name="panel-btn-radius" type="i"><default>0</default></key>
    <key name="panel-btn-pad-min" type="i"><default>4</default></key>
    <key name="panel-btn-pad-nat" type="i"><default>8</default></key>
    <key name="panel-btn-bg-hover" type="s"><default>'rgba(255,255,255,0.1)'</default></key>
    <key name="panel-btn-bg-active" type="s"><default>'rgba(255,255,255,0.2)'</default></key>
    <key name="panel-btn-hover-enabled" type="b"><default>false</default></key>

    <!-- Popup Menu -->
    <key name="popup-radius" type="i"><default>12</default></key>
    <key name="popup-shadow-enabled" type="b"><default>true</default></key>
    <key name="popup-shadow-color" type="s"><default>'rgba(0,0,0,0.5)'</default></key>
    <key name="popup-shadow-x" type="i"><default>0</default></key>
    <key name="popup-shadow-y" type="i"><default>4</default></key>
    <key name="popup-shadow-blur" type="i"><default>12</default></key>
    <key name="popup-shadow-spread" type="i"><default>4</default></key>

    <key name="popup-border-size" type="i"><default>0</default></key>
    <key name="popup-border-style" enum="dev.lethil.lesion.BorderStyle"><default>'solid'</default></key>
    <key name="popup-border-color" type="s"><default>'rgba(255,255,255,0.1)'</default></key>

  </schema>
</schemalist>